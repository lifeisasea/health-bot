# Скопируй этот файл в .env и заполни значения.

# Ключ MiniMax (формат sk-...). Получить/отозвать: https://platform.minimax.io
MINIMAX_API_KEY=

# Адрес и модель MiniMax (менять не нужно).
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3

# Резервная модель Claude (необязательно). Используется, когда MiniMax не справился.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Токен Telegram-бота от @BotFather (выглядит как 123456789:AAE...).
TELEGRAM_BOT_TOKEN=

# Твой числовой Telegram ID (бот будет отвечать только тебе). Узнать: @userinfobot
OWNER_ID=

# Часовой пояс для ежедневных/недельных сводок.
# Бэкап истории в приватный HF Dataset (для деплоя на Hugging Face).
HF_TOKEN=
HF_BACKUP_REPO=

TIMEZONE=Europe/Moscow

# Во сколько присылать дневной разбор питания (ЧЧ:ММ) и в какой день недели — недельную сводку.
DAILY_SUMMARY_TIME=21:30
WEEKLY_SUMMARY_DAY=sun
WEEKLY_SUMMARY_TIME=10:00

PRIMARY_MODEL=claude
